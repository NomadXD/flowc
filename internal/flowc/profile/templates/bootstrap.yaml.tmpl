# Envoy bootstrap configuration generated by FlowC
# Gateway: {{.GatewayName}} (node: {{.NodeID}})
# Profile: {{.ProfileType}}
node:
  cluster: {{.ClusterName}}
  id: {{.NodeID}}

dynamic_resources:
  ads_config:
    api_type: GRPC
    transport_api_version: V3
    grpc_services:
    - envoy_grpc:
        cluster_name: {{.XDSClusterName}}
  cds_config:
    resource_api_version: V3
    ads: {}
  lds_config:
    resource_api_version: V3
    ads: {}

static_resources:
  clusters:
  - name: {{.XDSClusterName}}
    connect_timeout: 5s
    type: LOGICAL_DNS
    typed_extension_protocol_options:
      envoy.extensions.upstreams.http.v3.HttpProtocolOptions:
        "@type": type.googleapis.com/envoy.extensions.upstreams.http.v3.HttpProtocolOptions
        explicit_http_config:
          http2_protocol_options: {}
    load_assignment:
      cluster_name: {{.XDSClusterName}}
      endpoints:
      - lb_endpoints:
        - endpoint:
            address:
              socket_address:
                address: {{.ControlPlaneHost}}
                port_value: {{.ControlPlanePort}}

admin:
  address:
    socket_address:
      address: 0.0.0.0
      port_value: {{.AdminPort}}
